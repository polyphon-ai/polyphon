# Apple credentials for local signing and notarization.
# Copy to .env.release and fill in your values.
# .env.release is gitignored — never commit it.
#
# Used by: make publish

# The name of your Developer ID Application certificate in Keychain Access.
# Find it with: security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)

# Your Apple ID (email address used for App Store Connect / developer.apple.com)
APPLE_ID=you@example.com

# App-specific password for notarization.
# Generate at: https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your 10-character Apple Developer Team ID.
# Find it at: https://developer.apple.com/account → Membership Details
APPLE_TEAM_ID=XXXXXXXXXX
