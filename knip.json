{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/main/index.ts",
        "src/main/preload.ts",
        "src/shared/api.ts",
        "src/shared/types.ts",
        "src/sdk/index.ts",
        "src/sdk/testing/index.ts",
        "vite.*.config.ts",
        "e2e/**/*.ts",
        "src/**/*.test.{ts,tsx}",
        "src/**/*.integration.test.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "e2e/**/*.ts",
        "vite.*.config.ts"
      ]
    },
    "packages/poly": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "geist",
    "tailwindcss",
    "@electron-forge/maker-dmg",
    "@electron-forge/maker-zip",
    "@electron-forge/plugin-fuses",
    "@electron-forge/plugin-vite",
    "@electron/fuses",
    "@electron/rebuild",
    "@vitest/coverage-v8"
  ]
}
